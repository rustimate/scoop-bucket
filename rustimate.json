{
    "version": "0.1.0",
    "description": "CLI animation engine and RSL for technical concepts.",
    "homepage": "https://qubitai.in/rustimate.html",
    "license": "Commercial",
    "url": "https://github.com/rustimate/rustimate/releases/download/v0.1.0/rustimate-windows-x86_64.zip",
    "hash": "FEC38E2A721F86FF9B49496A120CB3D9A8F7425D3DB5151F37B76DF3343BE435",
    "bin": "rustimate.exe",
    "checkver": "github",
    "uninstaller": {
    "script": [
            "if (Test-Path \"$env:USERPROFILE\\.rustimate\") { Remove-Item -Recurse -Force \"$env:USERPROFILE\\.rustimate\" }",
            "Write-Host ''",
            "Write-Host 'Rustimate uninstalled successfully.' -ForegroundColor Green",
            "Write-Host 'Note: Generated .mp4 and .rsl files were not removed.' -ForegroundColor Yellow",
            "Write-Host 'Please delete them manually from your project folders if needed.' -ForegroundColor Yellow"
        ]
    },
    "autoupdate": {
        "url": "https://github.com/rustimate/rustimate/releases/download/v$version/rustimate-windows-x86_64.zip"
    }
}
